# GitLab — configuración local
# Copiar a .env y ajustar según el entorno

# Directorio donde se persisten datos, logs y configuración de GitLab
GITLAB_HOME=./gitlab-data

# Versión de la imagen (usar "latest" o fijar una versión, ej: 17.6.0-ce.0)
GITLAB_VERSION=latest

# URL con la que se accede a GitLab desde el navegador
# Debe incluir el puerto si no es 80/443
GITLAB_EXTERNAL_URL=http://localhost:8929

# Puerto HTTP expuesto en el host (nginx dentro del contenedor escucha en este mismo puerto)
GITLAB_HTTP_PORT=8929

# Puerto HTTPS expuesto en el host
GITLAB_HTTPS_PORT=8930

# Puerto SSH expuesto en el host (para git clone vía SSH)
GITLAB_SSH_PORT=2222
